# Kite Connect API Keys
# Add as many keys as you want - numbered sequentially
# Each key supports 3 WebSocket connections x 3000 instruments = 9000 instruments

KITE_API_KEY_1=your_api_key_here
KITE_API_SECRET_1=your_api_secret_here
KITE_ACCESS_TOKEN_1=your_access_token_here

# KITE_API_KEY_2=second_api_key
# KITE_API_SECRET_2=second_api_secret
# KITE_ACCESS_TOKEN_2=second_access_token

# KITE_API_KEY_3=third_api_key
# KITE_API_SECRET_3=third_api_secret
# KITE_ACCESS_TOKEN_3=third_access_token

# Add more keys as needed (KITE_API_KEY_4, etc.)
# The system auto-distributes instruments across all available keys
