# ──────────────────────────────────────────────────────────────
# Rayena Backend — Environment Variables
# Copy this file to `.env` and fill in your own values.
# ──────────────────────────────────────────────────────────────

# Required: OpenAI API key (GPT-4o for AI features)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Required: JWT signing secret (used for local SQLite auth fallback)
# Generate a random string, e.g. `openssl rand -hex 32`
JWT_SECRET=replace-this-with-a-long-random-string

# Local SQLite database (used when Firebase is not configured)
DATABASE_URL=sqlite+aiosqlite:///./rayena.db

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ──────────────────────────────────────────────────────────────
# Firebase (production)
# Required if you want to use Firestore + Firebase Auth in production
# ──────────────────────────────────────────────────────────────

# Firebase project ID (from Firebase Console → Project Settings)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Default storage bucket (usually <project-id>.firebasestorage.app)
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# EITHER provide a path to a service account JSON file:
FIREBASE_SERVICE_ACCOUNT_KEY=./serviceAccountKey.json

# OR paste the entire service account JSON inline (for Cloud Run, Heroku, etc.)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
